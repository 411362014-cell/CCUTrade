<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="CCUTrade.MainWindow"
    Width="900"
    Height="700"
    Title="CCUTrade">

    <ScrollViewer>

        <StackPanel Margin="20" Spacing="10">

            <TextBlock
                FontSize="28"
                FontWeight="Bold"
                Text="CCU 二手交易平台" />

            <TextBox
                Watermark="商品名稱"
                Text="{Binding Title}" />

            <TextBox
                Watermark="商品描述"
                Text="{Binding Description}" />

            <ComboBox
                ItemsSource="{Binding Categories}"
                SelectedItem="{Binding Category}" />

            <TextBox
                Watermark="價格"
                Text="{Binding Price}" />

            <Button
                Content="新增商品"
                Command="{Binding AddProductCommand}" />

            <TextBlock
                Margin="0,20,0,0"
                FontSize="20"
                FontWeight="Bold"
                Text="搜尋商品" />

            <TextBox
                Watermark="輸入關鍵字搜尋"
                Text="{Binding SearchText}" />

            <ComboBox
                ItemsSource="{Binding Categories}"
                SelectedItem="{Binding SelectedCategory}" />

            <Separator />

            <ItemsControl ItemsSource="{Binding FilteredProducts}">

                <ItemsControl.ItemTemplate>

                    <DataTemplate>

                        <Border
                            Padding="10"
                            Margin="0,0,0,10"
                            BorderThickness="1">

                            <StackPanel Spacing="5">

                                <TextBlock
                                    FontSize="20"
                                    FontWeight="Bold"
                                    Text="{Binding Title}" />

                                <TextBlock
                                    Text="{Binding Description}" />

                                <TextBlock
                                    Text="{Binding Category}" />

                                <TextBlock
                                    Text="{Binding Price}" />

                            </StackPanel>

                        </Border>

                    </DataTemplate>

                </ItemsControl.ItemTemplate>

            </ItemsControl>

        </StackPanel>

    </ScrollViewer>

</Window>